{
  "name": "nestjs-filter-grammar",
  "version": "0.0.1",
  "description": "Tree-sitter-powered filter DSL parser for NestJS with decorator-based column/operator declarations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "generate": "tree-sitter generate grammar.ts --js-runtime tsx"
  },
  "keywords": ["nestjs", "filter", "tree-sitter", "dsl"],
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^20.0.0",
    "tree-sitter": "^0.22.0",
    "tree-sitter-cli": "^0.26.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
