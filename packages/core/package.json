{
  "name": "@nestjs-filter-grammar/core",
  "version": "0.1.1",
  "description": "Chevrotain-based filter DSL parser for NestJS with decorator-based column/operator declarations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chevrotain": "^11.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "reflect-metadata": ">=0.1.13",
    "@nestjs/swagger": ">=7.0.0",
    "class-transformer": ">=0.5.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/node": "^20.0.0",
    "class-transformer": "^0.5.0",
    "reflect-metadata": "^0.2.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0"
  },
  "files": [
    "dist"
  ]
}
