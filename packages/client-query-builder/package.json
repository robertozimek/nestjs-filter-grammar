{
  "name": "@nestjs-filter-grammar/client-query-builder",
  "version": "0.1.3",
  "description": "Type-safe frontend query builder for @nestjs-filter-grammar — build filter and sort query strings for REST APIs, designed to work alongside OpenAPI-generated clients",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "filter",
    "query-builder",
    "frontend",
    "client",
    "openapi",
    "rest-api",
    "sorting",
    "filtering",
    "type-safe",
    "codegen",
    "swagger",
    "api-client",
    "query-string"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/robertozimek/nestjs-filter-grammar.git",
    "directory": "packages/client-query-builder"
  },
  "homepage": "https://github.com/robertozimek/nestjs-filter-grammar#readme",
  "bugs": {
    "url": "https://github.com/robertozimek/nestjs-filter-grammar/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "filter-grammar": "./bin/filter-grammar.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "js-yaml": "^4.0.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.19.37"
  },
  "files": [
    "dist",
    "bin"
  ]
